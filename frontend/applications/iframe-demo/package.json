{
  "name": "@wippy/iframe-demo",
  "version": "1.0.0",
  "specification": "wippy-component-1.0",
  "title": "Iframe Demo",
  "description": "Demo page showing web components embedded in a child iframe, with theme override support",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "browser": "dist/app.js",
  "wippy": {
    "type": "page",
    "title": "Iframe Demo",
    "icon": "tabler:frame",
    "path": "dist/app.html",
    "proxy": {
      "enabled": true,
      "injections": {
        "css": {
          "fonts": true,
          "themeConfig": true,
          "iframe": true,
          "primevue": true,
          "markdown": false,
          "customCss": true,
          "customVariables": true
        },
        "tailwindConfig": true,
        "resizeObserver": false,
        "preventLinkClicks": false,
        "iconifyIcons": true,
        "errorCapture": true
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --mode development",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix"
  },
  "dependencies": {
    "@wippy-fe/theme": "^0.0.22"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "@wippy-fe/types-global-proxy": "^0.0.22",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "3",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.22",
    "axios": "^1.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  }
}
