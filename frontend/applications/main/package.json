{
  "name": "@wippy/frontend",
  "version": "1.0.0",
  "private": true,
  "specification": "wippy-component-1.0",
  "title": "Wippy App",
  "browser": "dist/app.js",
  "wippy": {
    "type": "page",
    "path": "dist/app.html",
    "proxy": {
      "css": {
        "prime_vue": true,
        "custom_css": true,
        "custom_variables": true
      }
    }
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "vue-tsc --build --force"
  },
  "devDependencies": {
    "@iconify/vue": "^4.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "axios": "^1.7.0",
    "postcss": "^8.4.0",
    "primevue": "^4.0.0",
    "tailwindcss": "3",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@iconify/vue": "^4.0.0",
    "axios": "^1.0.0",
    "primevue": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  }
}
