{
  "name": "@example/model-gallery",
  "version": "1.0.0",
  "specification": "wippy-component-1.0",
  "title": "Model Gallery",
  "description": "A card grid of AI models demonstrating proxy API fetch (api.get) with PrimeVue components (Button, Tag) in unstyled mode styled by Tailwind + PrimeUI.",
  "browser": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "dependencies": {
    "@wippy-fe/webcomponent-core": "file:../../npm/webcomponent-core",
    "@wippy-fe/webcomponent-vue": "file:../../npm/webcomponent-vue",
    "primevue": "^4.3.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.3",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwind-scrollbar": "^3.0.0",
    "tailwindcss": "3",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@wippy-fe/proxy": "^0.0.3",
    "vue": "^3.5.0"
  },
  "wippy": {
    "tagName": "example-model-gallery",
    "type": "widget",
    "props": {
      "type": "object",
      "properties": {
        "show-details": {
          "type": "boolean",
          "default": true,
          "description": "Whether to show model details (description, capabilities)"
        }
      }
    },
    "scripts": {
      "build": "build",
      "debug": "build:debug",
      "test": "lint"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --mode development",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix"
  }
}
