{
  "name": "@example/uploads-component",
  "version": "1.0.0",
  "specification": "wippy-component-1.0",
  "title": "File Upload Manager",
  "description": "A comprehensive file upload and management component with drag-and-drop, real-time progress tracking, and file listing.",
  "browser": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "dependencies": {
    "@wippy-fe/webcomponent-core": "file:../../npm/webcomponent-core",
    "@wippy-fe/webcomponent-vue": "file:../../npm/webcomponent-vue"
  },
  "devDependencies": {
    "@wippy-fe/proxy": "^0.0.3",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwind-scrollbar": "^3.0.0",
    "tailwindcss": "3",
    "tailwindcss-primeui": "^0.6.1",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@iconify/vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.3",
    "luxon": "^3.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.5.0"
  },
  "wippy": {
    "tagName": "uploads-manager",
    "type": "widget",
    "props": {
      "type": "object",
      "properties": {
        "allowed-types": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Array of allowed MIME types (empty for all types)"
        },
        "max-file-size": {
          "type": "number",
          "default": 104857600,
          "description": "Maximum file size in bytes (100MB default)"
        }
      }
    },
    "scripts": {
      "build": "build",
      "debug": "build:debug"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --mode development",
    "dev": "vite build --watch",
    "preview": "vite preview",
    "type-check": "vue-tsc --build --force"
  }
}
