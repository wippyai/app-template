{
  "name": "@example/chart-circle",
  "version": "1.0.0",
  "specification": "wippy-component-1.0",
  "title": "Chart Circle",
  "description": "A doughnut chart demonstrating bundled third-party library (Chart.js) usage.",
  "browser": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "dependencies": {
    "@wippy-fe/theme": "^0.0.8",
    "@wippy-fe/webcomponent-core": "^0.0.8",
    "@wippy-fe/webcomponent-vue": "^0.0.8",
    "chart.js": "^4.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@wippy-fe/proxy": "^0.0.8",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@wippy-fe/proxy": "^0.0.8",
    "vue": "^3.5.0"
  },
  "wippy": {
    "tagName": "example-chart-circle",
    "type": "widget",
    "props": {
      "type": "object",
      "properties": {
        "labels": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Red",
            "Blue",
            "Yellow"
          ],
          "description": "Labels for chart segments"
        },
        "values": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "default": [
            300,
            50,
            100
          ],
          "description": "Values for chart segments"
        },
        "title": {
          "type": "string",
          "default": "Sample Chart",
          "description": "Chart title"
        }
      }
    },
    "scripts": {
      "build": "build",
      "debug": "build:debug",
      "test": "lint"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --mode development",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix"
  }
}
