{
  "name": "@example/counter-persist",
  "version": "1.0.0",
  "specification": "wippy-component-1.0",
  "title": "Counter Persist",
  "description": "A counter widget demonstrating Pinia state persistence across iframe reloads.",
  "browser": "dist/index.js",
  "files": [
    "dist/",
    "src/",
    "package.json"
  ],
  "dependencies": {
    "@wippy-fe/theme": "^0.0.16",
    "@wippy-fe/webcomponent-core": "^0.0.16",
    "@wippy-fe/webcomponent-vue": "^0.0.16",
    "primevue": "^4.3.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@wippy-fe/pinia-persist": "^0.0.16",
    "@wippy-fe/proxy": "^0.0.16",
    "pinia": "^2.1.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "3",
    "typescript": "^5.0.0",
    "vite": "^6.0.0",
    "vue": "^3.5.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.0"
  },
  "peerDependencies": {
    "@wippy-fe/proxy": "^0.0.16",
    "pinia": "^2.1.0",
    "vue": "^3.5.0"
  },
  "wippy": {
    "tagName": "example-counter-persist",
    "type": "widget",
    "props": {
      "type": "object",
      "properties": {
        "persist-key": {
          "type": "string",
          "description": "Key prefix for state persistence. Different keys = separate state."
        }
      }
    },
    "events": {
      "type": "object",
      "properties": {
        "count-changed": {
          "type": "object",
          "properties": {
            "count": { "type": "number" }
          },
          "description": "Fired when count value changes"
        }
      }
    },
    "scripts": {
      "build": "build",
      "debug": "build:debug",
      "test": "lint"
    }
  },
  "scripts": {
    "build": "vite build",
    "build:debug": "vite build --mode development",
    "dev": "vite build --watch",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix"
  }
}
